{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stablepay",
  "colors": {
    "primary": "#111111",
    "light": "#FFFFFF",
    "dark": "#111111"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@stablepay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://stablepay-dashboard-production.up.railway.app/"
    }
  },
  "api": {
    "openapi": "openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "mdx": {
      "server": "https://stablepay-money-api-production.up.railway.app",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
  "tabs": [
    {
      "tab": "Stablepay Moneyout API",
      "groups": [
        {
          "group": "Payments",
          "pages": [
            "api-reference/payments/submit-moneyout",
            "api-reference/payments/get-payment"
          ]
        },
        {
          "group": "FX",
          "pages": [
            "api-reference/fx/convert"
          ]
        },
        {
          "group": "Webhooks",
          "pages": [
            "api-reference/webhooks/register",
            "api-reference/webhooks/replay-event"
          ]
        }
      ]
    }
  ]
},
  "footer": {
    "socials": {
      "github": "https://github.com/katlegorphele/stablepay"
    }
  }
}
