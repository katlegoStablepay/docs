{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stablepay",
  "colors": {
    "primary": "#111111",
    "light": "#FFFFFF",
    "dark": "#111111"
  },
  "font": {
    "headings": {
      "family": "Poppins",
      "weight": 500
    },
    "body": {
      "family": "Poppins",
      "weight": 300
    }
  },
  "custom": {
    "stylesheets": ["/custom.css"]
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/Spay_Logo_Dark.png",
    "dark": "/logo/Spay_Logo_Light.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@stablepay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://console.stablepay.io/"
    }
  },
  "api": {
    "openapi": "openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "mdx": {
      "server": "https://stablepay-money-api-production.up.railway.app",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
  "tabs": [
    {
      "tab": "Stablepay Onchain API",
      "groups": [
        {
          "group": "Account",
          "pages": [
            "api-reference/validate"
          ]
        },
        {
          "group": "Payments",
          "pages": [
            "api-reference/convert",
            "api-reference/submit-moneyout",
            "api-reference/submit-moneyin",
            "api-reference/get-payment"
          ]
        },
        {
          "group": "Webhooks",
          "pages": [
            "api-reference/webhooks/register",
            "api-reference/webhooks/replay-event",
            "api-reference/webhooks/list-events"
          ]
        }
      ]
    }
  ]
},
  "footer": {
    "socials": {
      "github": "https://github.com/katlegorphele/stablepay"
    }
  }
}
