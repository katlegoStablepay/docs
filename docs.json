{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stablepay",
  "colors": {
    "primary": "#111111",
    "light": "#FFFFFF",
    "dark": "#111111"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@stablepay.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://stablepay-dashboard-production.up.railway.app/"
    }
  },
  "api": {
    "openapi": "openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "mdx": {
      "server": "https://stablepay-money-api-production.up.railway.app",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Payments",
            "pages": [
              "api-reference/payments/submit-moneyout",
              "api-reference/payments/get-payment",
              "api-reference/payments/list-payments"
            ]
          },
          {
            "group": "FX Rates",
            "pages": [
              "api-reference/fx/convert"
            ]
          },
          {
            "group": "Quotes",
            "pages": [
              "api-reference/quotes/create-quote",
              "api-reference/quotes/get-quote"
            ]
          },
          {
            "group": "Balances",
            "pages": [
              "api-reference/balances/get-balances"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api-reference/webhooks/register",
              "api-reference/webhooks/list-events",
              "api-reference/webhooks/replay-event"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "api-reference/analytics/get-analytics"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/katlegorphele/stablepay"
    }
  }
}
